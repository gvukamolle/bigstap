# BIGSTEP.RU — пример production-окружения для VPS (Docker Compose).
# Скопируйте в .env рядом с docker-compose.yml и заполните значения:
#   cp .env.production.example .env
# Реальный .env НИКОГДА не коммитьте (он в .gitignore).

# --- Секрет Payload (ОБЯЗАТЕЛЕН в production, >= 16 символов) ---
# Длинный случайный секрет. Сгенерировать:  openssl rand -base64 48
PAYLOAD_SECRET=

# --- Публичный адрес сайта ---
# Используется для canonical, sitemap, Open Graph, JSON-LD. Без слеша в конце.
# Должен совпадать с доменом за reverse-proxy.
NEXT_PUBLIC_SITE_URL=https://bigstep.ru

# --- PostgreSQL ---
# Пароль БД. Используется и контейнером postgres, и строкой подключения DATABASE_URI ниже —
# значения должны совпадать.
POSTGRES_PASSWORD=CHANGE_ME

# Хост = имя сервиса в compose (postgres), порт 5432, база/пользователь = bigstep.
# Подставьте сюда тот же пароль, что и в POSTGRES_PASSWORD.
DATABASE_URI=postgres://bigstep:CHANGE_ME@postgres:5432/bigstep

# --- Bootstrap первого админа Payload (см. docs/security-bootstrap.md) ---
# Длинный одноразовый токен (openssl rand -base64 48). Порядок: открыть /bootstrap-admin,
# ввести токен, создать первого админа, затем ОЧИСТИТЬ этот токен и перезапустить контейнер.
# Без токена маршруты создания первого пользователя в проде отдают 404.
PAYLOAD_BOOTSTRAP_TOKEN=

# --- Первичное создание схемы БД (drizzle push) ---
# В production push выключен (защита от потери данных). Для ПЕРВОГО запуска на чистой Postgres
# задайте true, поднимите стек, дождитесь создания таблиц, затем верните пустым и перезапустите.
# Подробности — docs/deployment.md.
PAYLOAD_DB_PUSH=

# --- Оплата ЮKassa ---
# Ключи можно задать здесь ИЛИ после запуска в админке («Интеграции: оплата и доставка») —
# значения из админки имеют приоритет и применяются без перезапуска контейнера.
# Заполнение ОБОИХ переменных включает приём заказов в production: чекаут создаёт платёж и
# редиректит покупателя на оплату. Без них POST /api/checkout в проде отдаёт 404 (режим прототипа).
# Секреты — только серверные (не NEXT_PUBLIC_*). Зарегистрируйте вебхук payment.succeeded и
# payment.canceled на https://ВАШ_ДОМЕН/api/yookassa/webhook (HTTPS обязателен).
# Чек НПД самозанятый формирует отдельно в «Мой налог» — ЮKassa их не делает с 29.12.2025.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# --- Доставка CDEK ---
# Ключи можно задать здесь ИЛИ после запуска в админке («Интеграции: оплата и доставка»).
# Заполнение ОБОИХ переменных включает подгрузку реальных пунктов выдачи по городу в чекауте
# (прокси /api/cdek/pickup-points). Без них показываются прототипные пункты. Секреты только серверные.
# CDEK_API_MODE=test переключает на тестовый контур api.edu.cdek.ru (для боевого — оставить пустым).
# Расчёт стоимости доставки (калькулятор) и регистрация отправления — следующий шаг (нужен договор/склад).
CDEK_CLIENT_ID=
CDEK_CLIENT_SECRET=
CDEK_API_MODE=
