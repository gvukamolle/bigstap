DATABASE_URI=
SQLITE_DATABASE_URL=file:payload-local.db
POSTGRES_PASSWORD=bigstep
# Свой секрет (>=16 симв.): openssl rand -base64 48. Пусто = dev-фоллбэк; в production обязателен.
PAYLOAD_SECRET=
PAYLOAD_BOOTSTRAP_TOKEN=
PAYLOAD_SEED_ADMIN_USERNAME=
PAYLOAD_SEED_ADMIN_PASSWORD=
PAYLOAD_SEED_ADMIN_EMAIL=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Ключи ЮKassa/СДЭК можно задать здесь ИЛИ в админке («Интеграции: оплата и доставка»).
# Значения из админки имеют приоритет; пустые поля в админке = эти переменные.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
CDEK_CLIENT_ID=
CDEK_CLIENT_SECRET=
# test = тестовый контур api.edu.cdek.ru (только для env-кредов; в админке контур — селектом).
CDEK_API_MODE=
